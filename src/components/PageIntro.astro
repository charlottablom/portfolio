---
import Circle from './Circle.astro';

interface Props {
  title: string;
  circleRotation?: number;
}

const { title, circleRotation = 0 } = Astro.props;
---

<section class="page-intro container">
	<div class="page-intro__text">
		<h1>{title}</h1>
		<slot />
	</div>
	<Circle rotation={circleRotation} />
</section>

<style>
  /*
    align-items: flex-start (not center) keeps the heading at the same
    vertical position on every page. Centering would tie the heading's
    position to how tall the surrounding text is, which varies a lot
    between pages (a full hero vs. just a title) and made it visibly
    shift when navigating between them.
  */
  .page-intro {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-block: var(--space-5) var(--space-4);
  }

  .page-intro__text {
    flex: 1 1 28rem;
  }
</style>
