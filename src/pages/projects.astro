---
import Layout from '../layouts/Layout.astro';
import PageIntro from '../components/PageIntro.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
---

<Layout title="Projects — Charlotta Blom" description="Selected projects by Charlotta Blom.">
	<PageIntro title="Projects" circleRotation={180} />

	<section class="projects container">
		{projects.length === 0 ? (
			<p class="projects__empty">Projects will be added here.</p>
		) : (
			<ul class="projects__list">
				{projects.map((project) => (
					<li>{project.data.title}</li>
				))}
			</ul>
		)}
	</section>
</Layout>

<style>
  .projects {
    padding-block: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .projects__empty {
    color: var(--color-muted);
  }
</style>
