---
import Layout from '../layouts/Layout.astro';
import PageIntro from '../components/PageIntro.astro';
import ProjectTimeline from '../components/ProjectTimeline.astro';
import { getCollection } from 'astro:content';
import { featuredProjects } from '../config/featured-projects';

const allProjects = await getCollection('projects');

// Same featuredProjects list the Projects page uses, so a job-application
// branch that curates that list adapts this timeline too, automatically.
const projects =
  featuredProjects.length === 0
    ? allProjects
    : featuredProjects
        .map((slug) => allProjects.find((project) => project.id === slug))
        .filter((project) => project !== undefined);

const timelineEntries = projects
  .slice()
  .sort((a, b) => Number(b.data.year) - Number(a.data.year))
  .map((project) => ({
    slug: project.id,
    title: project.data.title,
    year: project.data.year,
    isGroupProject: (project.data.collaborators?.length ?? 0) > 0,
  }));
---

<Layout title="Charlotta Blom — Portfolio">
	<PageIntro title="Charlotta Blom" circleRotation={0}>
		<p class="hero__tagline">Architecture — Landscape — Computational Design</p>
		<p class="hero__intro">Designing across disciplines, scales, and methods.</p>
	</PageIntro>

	<section class="section container">
		<h2>Selected Work</h2>
		{timelineEntries.length === 0 ? (
			<p class="section__empty">Projects will be added here.</p>
		) : (
			<ProjectTimeline entries={timelineEntries} />
		)}
	</section>
</Layout>

<style>
  .hero__tagline {
    margin-top: var(--space-2);
    font-size: var(--font-size-lg);
    color: var(--color-muted);
  }

  .hero__intro {
    margin-top: var(--space-3);
    max-width: 40rem;
    font-size: var(--font-size-lg);
  }

  .section {
    padding-block: var(--space-4);
    border-top: 1px solid var(--color-border);
  }

  .section h2 {
    margin-bottom: var(--space-3);
  }

  .section__empty {
    color: var(--color-muted);
  }
</style>
